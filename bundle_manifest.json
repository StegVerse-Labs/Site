{
  "schema": "stegverse_bundle_manifest.v1",
  "bundle_id": "stage6-site-publication-bundle",
  "target_repo": "StegVerse-Labs/Site",
  "no_workflows": true,
  "purpose": "Publish Stage 6 unified gate results through the Site public proof surface.",
  "authority_boundary": "formalism-tests produces receipts. Site publishes receipts. Site must not become the authority for receipts.",
  "files": [
    {
      "path": "stage6-unified-gate-results.html",
      "action": "create",
      "description": "New public Stage 6 unified gate results page."
    },
    {
      "path": "transition-release-index.html",
      "action": "replace",
      "description": "Full replacement that adds Stage 6 results page to navigation and canonical page list."
    },
    {
      "path": "transition-table-classes.html",
      "action": "replace",
      "description": "Full replacement that links to Stage 6 results and supports reset/evolve decisions."
    },
    {
      "path": "README.md",
      "action": "include",
      "description": "Bundle explanation and verification checklist."
    },
    {
      "path": "bundle_manifest.json",
      "action": "include",
      "description": "Manifest for this bundle."
    }
  ],
  "verification": {
    "expected_public_pages": [
      "https://stegverse-labs.github.io/Site/stage6-unified-gate-results.html",
      "https://stegverse-labs.github.io/Site/transition-release-index.html",
      "https://stegverse-labs.github.io/Site/transition-table-classes.html"
    ],
    "expected_stage6_summary": {
      "candidate_count": 10,
      "test_count": 94,
      "overall_status": "PASS"
    }
  }
}