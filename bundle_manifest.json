{
  "schema": "stegverse_bundle_manifest.v1",
  "bundle_id": "transition-discovery-color-sync-bundle",
  "target_repo": "StegVerse-Labs/Site",
  "no_workflows": true,
  "purpose": "Restore the transition discovery map and synchronize transition classification colors to the same 0-5 completion scale.",
  "authority_boundary": "formalism-tests produces receipts. Site publishes receipts. Site must not become the authority for receipts.",
  "files": [
    {
      "path": "transition-discovery.html",
      "action": "create_or_replace",
      "description": "Restored data-driven discovery map."
    },
    {
      "path": "data/formalism-tests/transition-discovery-map.json",
      "action": "create_or_replace",
      "description": "Shared completion-level and color-scale data."
    },
    {
      "path": "transition-table-classes.html",
      "action": "replace",
      "description": "Applies discovery color scale to transition classifications."
    },
    {
      "path": "transition-release-index.html",
      "action": "replace",
      "description": "Adds discovery page to release navigation and canonical pages."
    },
    {
      "path": "README.md",
      "action": "include",
      "description": "Bundle explanation."
    },
    {
      "path": "bundle_manifest.json",
      "action": "include",
      "description": "Bundle manifest."
    }
  ],
  "completion_scale": "0-5",
  "shared_data_path": "data/formalism-tests/transition-discovery-map.json"
}
