{
  "schema": "stegverse_bundle_manifest.v1",
  "bundle_id": "transition-table-mobile-expand-bundle",
  "target_repo": "StegVerse-Labs/Site",
  "no_workflows": true,
  "purpose": "Make transition-table-classes mobile-friendly with expandable periodic-style transition tiles.",
  "files": [
    {
      "path": "transition-table-classes.html",
      "action": "replace",
      "description": "Desktop table plus mobile expandable transition tiles."
    },
    {
      "path": "README.md",
      "action": "include",
      "description": "Bundle explanation."
    },
    {
      "path": "bundle_manifest.json",
      "action": "include",
      "description": "Bundle manifest."
    }
  ],
  "data_sources": [
    "data/formalism-tests/transition-table-classes.json",
    "data/formalism-tests/transition-discovery-map.json"
  ],
  "mobile_breakpoint_px": 820
}
