{
  "schema": "stegverse_bundle_manifest.v1",
  "bundle_id": "site-single-source-status-bundle",
  "target_repo": "StegVerse-Labs/Site",
  "no_workflows": true,
  "purpose": "Convert main transition status pages to a single Site status source.",
  "single_status_source": "data/formalism-tests/transition-proof-surface.json",
  "shared_renderer": "assets/transition-site-status.js",
  "files": [
    {
      "path": "data/formalism-tests/transition-proof-surface.json",
      "action": "replace"
    },
    {
      "path": "assets/transition-site-status.js",
      "action": "create_or_replace"
    },
    {
      "path": "transition-proof-surface.html",
      "action": "replace"
    },
    {
      "path": "transition-release-index.html",
      "action": "replace"
    },
    {
      "path": "transition-development-status.html",
      "action": "replace"
    },
    {
      "path": "transition-milestones.html",
      "action": "replace"
    },
    {
      "path": "transition-verification-guide.html",
      "action": "replace"
    },
    {
      "path": "transition-replay-packet.html",
      "action": "replace"
    },
    {
      "path": "stage6-unified-gate-results.html",
      "action": "replace"
    },
    {
      "path": "README.md",
      "action": "include"
    },
    {
      "path": "bundle_manifest.json",
      "action": "include"
    }
  ]
}
