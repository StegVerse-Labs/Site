{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stegverse-labs.github.io/Site/schemas/ai-entry-governed-live-activation-request.schema.json",
  "title": "StegVerse AI Entry Governed Live Activation Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "requested_by",
    "requested_activation",
    "scope",
    "preconditions",
    "authority_boundary",
    "fail_closed_boundary"
  ],
  "properties": {
    "schema_version": {
      "const": "stegverse.ai_entry.governed_live_activation_request.v0.1"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "requested_by": {
      "type": "string",
      "minLength": 1
    },
    "requested_activation": {
      "type": "string",
      "enum": [
        "provider_adapter_calls",
        "sdk_access_calls",
        "receipt_issuer",
        "execution_authority_path",
        "repo_mutation_path"
      ]
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "surface", "live_calls_requested"],
      "properties": {
        "repo": {"type": "string", "minLength": 1},
        "surface": {"type": "string", "minLength": 1},
        "live_calls_requested": {"type": "boolean", "const": false}
      }
    },
    "preconditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "satisfied"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "satisfied": {"type": "boolean", "const": false}
        }
      }
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authority_issued", "execution_allowed", "credential_access_allowed"],
      "properties": {
        "authority_issued": {"type": "boolean", "const": false},
        "execution_allowed": {"type": "boolean", "const": false},
        "credential_access_allowed": {"type": "boolean", "const": false}
      }
    },
    "fail_closed_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_decision", "recovery_required", "manual_override_allowed"],
      "properties": {
        "default_decision": {"type": "string", "const": "DENY"},
        "recovery_required": {"type": "boolean", "const": true},
        "manual_override_allowed": {"type": "boolean", "const": false}
      }
    }
  }
}
