{
  "schema_version": "1.1.0",
  "mode": "GOVERNED_GATEWAY_WITH_LOCAL_FALLBACK",
  "enabled": true,
  "endpoint": "https://stegverse-ecosystem-chat-gateway.onrender.com/api/ecosystem-chat",
  "health_endpoint": "https://stegverse-ecosystem-chat-gateway.onrender.com/health",
  "timeout_ms": 20000,
  "fallback": "LOCAL_CLASSIFICATION",
  "discovery": {
    "enabled": true,
    "required_node_id": "ecosystem-chat-portable-node",
    "advertisement_endpoints": [
      "https://stegverse-ecosystem-chat-gateway.onrender.com/api/stegverse-node"
    ],
    "timeout_ms": 4000,
    "fallback": "STATIC_GATEWAY_CONFIG"
  },
  "authority_boundary": {
    "site_execution_authority": false,
    "gateway_execution_authority": false,
    "gateway_receipt_is_final": false,
    "master_records_authority": false,
    "node_discovery_grants_authority": false,
    "node_advertisement_is_publication_authority": false
  }
}
