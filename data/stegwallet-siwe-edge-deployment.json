{
  "schema": "stegwallet.siwe_edge_deployment.v2",
  "status": "AUTHORIZATION_REQUIRED",
  "edge_model": "platform-agnostic-same-origin-proxy",
  "canonical_origin": "https://stegverse.org",
  "route_pattern": "stegverse.org/api/stegwallet/siwe/*",
  "required_capabilities": [
    "exact route and method enforcement",
    "HTTPS termination",
    "client edge-token stripping",
    "edge-to-origin secret injection",
    "cookie and Set-Cookie preservation",
    "controlled forwarded headers",
    "no-store responses",
    "direct-origin authentication rejection"
  ],
  "optional_adapter_candidates": [
    "cloudflare-worker",
    "nginx",
    "caddy",
    "envoy",
    "traefik",
    "kubernetes-ingress"
  ],
  "selected_adapter": null,
  "provider_specific_adapter_required": false,
  "upstream_origin": null,
  "upstream_origin_verified": false,
  "edge_secret_provisioned": false,
  "edge_secret_matches_origin": false,
  "edge_runtime_authorized": false,
  "edge_adapter_deployed": false,
  "route_observed": false,
  "site_configuration_promoted": false,
  "wallet_authenticated": false,
  "transaction_authority": false,
  "execution_authority": false,
  "delegation_authority": false,
  "custody_recorded": false,
  "activation_blockers": [
    "standards-compliant edge runtime not selected or authorized",
    "SIWE upstream origin not deployed or verified",
    "edge-to-origin secret not provisioned to both runtimes",
    "same-origin edge route not deployed",
    "same-origin health route not observed",
    "live activation receipt not produced"
  ]
}
