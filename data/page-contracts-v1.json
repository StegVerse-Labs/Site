    {
      "path": "data/next-transition-build-candidate-v1.json",
      "required_values": [
        {
          "json_path": "current_released_milestone",
          "equals": "MS-012 \u2014 Independent Replay Packet"
        },
        {
          "json_path": "current_candidate_milestone",
