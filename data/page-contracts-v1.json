        }
      ]
    },
    {
      "path": "data/transition-replay-packet-v1.json",
      "required_values": [
        {
          "json_path": "formal_milestone",
          "equals": "MS-012 \u2014 Independent Replay Packet"
        },
        {
          "json_path": "status",
          "equals": "pending_until_public_links_confirmed"
        },
        {
          "json_path": "current_verified_release.formal_milestone",
          "equals": "MS-011 \u2014 Public Verification Bundle"
        }
      ],
      "required_contains": [
        {
          "json_path": "replay_scope.selected_elements",
          "contains": "T13"
        },
        {
          "json_path": "replay_scope.selected_elements",
          "contains": "T14"
        }
