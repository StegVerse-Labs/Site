{
  "schema": "stegverse.governed-aspect-registry.v0.1",
  "authority_effect": "NONE",
  "default_resolution": "UNRESOLVED",
  "aspects": [
    {"id":"identity_participation","family":"identity","question":"Who or what participated?","does_not_prove":["ownership","authorship","authority","value"],"required_refs":["actor_refs","identity_refs"],"status_values":["declared","verified","pseudonymous","anonymous","unknown"]},
    {"id":"source_provenance","family":"provenance","question":"Where did the information or artifact come from?","does_not_prove":["ownership","originality","license"],"required_refs":["source_refs","acquisition_refs","hash_refs"],"status_values":["captured","derived","public","licensed","generated","unknown"]},
    {"id":"ownership_control","family":"rights","question":"Who owns, controls, possesses, licenses, or stewards it?","does_not_prove":["consent","authorship","admissibility"],"required_refs":["rights_claim_refs","verification_refs"],"status_values":["asserted","verified","licensed","assigned","contested","unknown"]},
    {"id":"consent_permission","family":"permission","question":"Which collection, processing, retention, projection, reuse, commercialization, training, publication, or settlement uses are allowed?","does_not_prove":["ownership","value","authority"],"required_refs":["consent_refs","purpose_refs","scope_refs"],"status_values":["granted","limited","narrowed","expired","revoked","unknown"]},
    {"id":"privacy_sensitivity","family":"privacy","question":"What disclosure or misuse risk applies?","does_not_prove":["value","scarcity","ownership"],"required_refs":["classification_refs"],"status_values":["public","private","confidential","restricted","regulated","unknown"]},
    {"id":"contribution","family":"contribution","question":"What information, labor, judgment, correction, evidence, coordination, or infrastructure was supplied?","does_not_prove":["causal_influence","value","payment"],"required_refs":["submission_refs"],"status_values":["observed","claimed","verified","disputed","unknown"]},
    {"id":"causal_influence","family":"causality","question":"How did the contribution affect a later governed result?","does_not_prove":["ownership","exclusive_authorship","realized_value"],"required_refs":["target_event_refs","evidence_refs","counterfactual_refs"],"status_values":["unassessed","low","medium","high","decisive","contested"]},
    {"id":"attribution","family":"credit","question":"How should bounded credit or responsibility be assigned?","does_not_prove":["ownership","exclusivity","compensation"],"required_refs":["attribution_policy_refs","evidence_refs"],"status_values":["individual","shared","collective","layered","provisional","contested","unresolved"]},
    {"id":"authorship","family":"authorship","question":"Who formed, directed, revised, generated, assembled, or controlled the expression?","does_not_prove":["ownership","license","value"],"required_refs":["creation_refs","revision_refs"],"status_values":["human","model","agent","joint","editorial","unknown"]},
    {"id":"originality_novelty","family":"novelty","question":"Relative to which corpus and time boundary is this new?","does_not_prove":["ownership","value","patentability"],"required_refs":["comparison_boundary_refs","search_refs"],"status_values":["session_novel","organization_novel","system_novel","publicly_novel","not_established"]},
    {"id":"scarcity_substitutability","family":"scarcity","question":"How rare, replaceable, exclusive, or time-sensitive is the contribution?","does_not_prove":["value","ownership","permission"],"required_refs":["market_or_availability_refs"],"status_values":["scarce","limited","substitutable","abundant","unknown"]},
    {"id":"labor_effort","family":"effort","question":"What human or machine effort was expended?","does_not_prove":["value","quality","admissibility"],"required_refs":["effort_measurement_refs"],"status_values":["measured","estimated","asserted","unknown"]},
    {"id":"compute_infrastructure","family":"cost","question":"Which inference, storage, network, orchestration, custody, reconstruction, security, and settlement resources were consumed?","does_not_prove":["value","contribution","outcome"],"required_refs":["usage_refs","cost_refs"],"status_values":["measured","estimated","unknown"]},
    {"id":"outcome_utility","family":"outcome","question":"What changed because of the interaction?","does_not_prove":["admissibility","realized_value","payment"],"required_refs":["outcome_refs"],"status_values":["observed","projected","claimed","no_effect","unknown"]},
    {"id":"realized_value","family":"value","question":"What benefit or avoided loss was observed against which baseline?","does_not_prove":["distribution_authority","payment","ownership"],"required_refs":["baseline_refs","measurement_refs","window_refs"],"status_values":["unassessed","projected","observed","verified","contested"]},
    {"id":"cost_externalities","family":"externality","question":"Which direct, indirect, shifted, environmental, social, legal, privacy, security, and opportunity costs exist?","does_not_prove":["inadmissibility","zero_value"],"required_refs":["cost_refs","affected_party_refs"],"status_values":["assessed","partial","unassessed","contested"]},
    {"id":"risk_harm","family":"risk","question":"What harms are foreseeable or observed, to whom, and with what likelihood, severity, reversibility, and mitigation?","does_not_prove":["inadmissibility","liability"],"required_refs":["risk_refs","mitigation_refs"],"status_values":["low","medium","high","critical","unknown"]},
    {"id":"admissibility","family":"governance","question":"May the transition proceed under current authority, policy, consent, evidence, and boundary conditions?","does_not_prove":["success","value","ownership"],"required_refs":["policy_refs","authority_refs","evidence_refs"],"status_values":["allow","deny","defer","quarantine","not_evaluated"]},
    {"id":"authority_delegation","family":"authority","question":"Who may inspect, decide, authorize, execute, override, revoke, settle, or publish?","does_not_prove":["admissibility","standing","capability"],"required_refs":["delegation_refs","scope_refs","validity_refs"],"status_values":["active","expired","revoked","insufficient","unknown"]},
    {"id":"standing_capability","family":"standing","question":"What future participation, access, reputation, or capability exists?","does_not_prove":["authority","permission","admissibility"],"required_refs":["standing_refs","capability_refs"],"status_values":["earned","assigned","limited","suspended","expired","unknown"]},
    {"id":"reward_incentive","family":"reward","question":"Which recognition class may apply?","does_not_prove":["distribution","settlement","payment"],"required_refs":["reward_policy_refs"],"status_values":["credit","standing","access","capability","governance","royalty_candidate","payment_candidate","none"]},
    {"id":"distribution_allocation","family":"distribution","question":"How may distributable value be divided?","does_not_prove":["settlement","payment_completion"],"required_refs":["allocation_policy_refs","contract_refs"],"status_values":["provisional","authorized","contested","blocked","unknown"]},
    {"id":"settlement","family":"settlement","question":"Was an authorized allocation finalized and receipted?","does_not_prove":["historical_correctness","absence_of_dispute"],"required_refs":["settlement_receipt_refs","custody_refs"],"status_values":["not_started","pending","settled","reversed","disputed"]},
    {"id":"jurisdiction_legal","family":"legal","question":"Which jurisdictions, classifications, reporting duties, and restrictions apply?","does_not_prove":["universal_legality","admissibility"],"required_refs":["jurisdiction_refs","legal_policy_refs"],"status_values":["assessed","partial","unknown","contested"]},
    {"id":"temporal_state_decay","family":"temporal","question":"How do relevance, consent, rights, value, standing, risk, and authority change over time?","does_not_prove":["current_validity"],"required_refs":["effective_time_refs","expiry_refs"],"status_values":["current","expiring","expired","superseded","deprecated","unknown"]},
    {"id":"dispute_competing_claims","family":"dispute","question":"Which claims or determinations conflict?","does_not_prove":["resolution","invalidity"],"required_refs":["competing_claim_refs","dispute_refs"],"status_values":["none","open","under_review","resolved","rejected"]},
    {"id":"fraud_gaming_manipulation","family":"integrity","question":"Is apparent value being manufactured through padding, duplication, collusion, identity splitting, fabricated evidence, circularity, or artificial scarcity?","does_not_prove":["fraud","intent"],"required_refs":["integrity_evidence_refs"],"status_values":["clear","flagged","quarantined","confirmed","unknown"]},
    {"id":"collective_network_contribution","family":"collective","question":"Is contribution distributed or non-separable across users, conversations, communities, tools, and prior work?","does_not_prove":["equal_shares","individual_attribution"],"required_refs":["network_refs","pool_policy_refs"],"status_values":["individual","shared","pooled","non_separable","unresolved"]},
    {"id":"derivation_transformation","family":"derivation","question":"How was a captured record transformed into a derived record?","does_not_prove":["accuracy","permission","verification"],"required_refs":["source_record_refs","method_refs","operator_refs"],"status_values":["captured","derived","combined","summarized","evaluated","unknown"]},
    {"id":"disclosure_projection","family":"projection","question":"Which facts may be shown to which audience and destination for which purpose?","does_not_prove":["custody","publication_authority","reuse_permission"],"required_refs":["purpose_refs","permission_refs","redaction_refs"],"status_values":["allow","deny","redacted","minimum_disclosure","unknown"]},
    {"id":"custody_reconstruction","family":"continuity","question":"Where are authoritative records retained and can state be reconstructed?","does_not_prove":["authority","admissibility","correctness"],"required_refs":["custody_refs","chain_refs","reconstruction_refs"],"status_values":["not_recorded","recorded","replayable","reconstructable","failed","unknown"]},
    {"id":"confidence_uncertainty","family":"epistemic","question":"How certain is each interpretive claim and what remains unresolved?","does_not_prove":["truth","admissibility"],"required_refs":["confidence_refs","uncertainty_refs"],"status_values":["low","medium","high","unknown","contested"]},
    {"id":"recovery_correction","family":"recovery","question":"Which correction, retraction, reversal, appeal, supersession, or recovery occurred?","does_not_prove":["historical_erasure","full_remediation"],"required_refs":["recovery_event_refs"],"status_values":["none","open","corrected","superseded","recovered","failed"]},
    {"id":"public_claim_communication","family":"communication","question":"What may be claimed externally without overstating evidence or authority?","does_not_prove":["marketing_permission","legal_sufficiency"],"required_refs":["claim_policy_refs","evidence_refs"],"status_values":["allowed","qualified","prohibited","under_review"]}
  ],
  "global_invariants": [
    "no_aspect_silently_grants_another",
    "missing_evidence_resolves_to_unresolved",
    "authoritative_changes_are_governed_events",
    "human_projection_does_not_remove_governed_distinctions",
    "browser_state_grants_no_authority_custody_payment_or_settlement",
    "competing_determinations_remain_visible",
    "history_is_append_only_with_governed_correction_or_supersession",
    "sensitivity_is_not_an_automatic_value_multiplier",
    "success_does_not_erase_invalid_consent_or_externalized_harm",
    "downstream_projection_requires_purpose_permission_redaction_and_minimum_disclosure"
  ]
}
