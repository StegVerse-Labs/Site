{
  "schema": "stegverse.bundle_ingestion_policy.v1",
  "policy_id": "ms012e3-installed-bundle-archive-v1",
  "formal_milestone": "MS-012E.3 \u2014 Installed Bundle Archive",
  "purpose": "Archive successfully installed bundles separately from incoming, failed, sandbox, and privileged queues.",
  "default_mode": "apply_changed_files",
  "queue": {
    "incoming_dir": "incoming",
    "installed_dir": "installed_bundles",
    "failed_dir": "failed_bundles",
    "privileged_dir": "privileged_queue",
    "sandbox_dir": "sandbox_queue",
    "process_order": "name_ascending",
    "skip_previously_failed_hashes": true,
    "skip_previously_applied_hashes": true,
    "continue_after_failure": true,
    "archive_installed_bundles": true,
    "quarantine_stale_incoming": true,
    "quarantine_already_seen_incoming": true,
    "stale_non_zip_files": true,
    "stale_already_seen_zip_files": true,
    "stale_routed_zip_files": true,
    "delete_original_after_install_archive": false,
    "delete_original_after_quarantine": false
  },
  "path_mappings": [
    {
      "bundle_prefix": "github/workflows/",
      "repo_prefix": ".github/workflows/",
      "reason": "Upload-safe bundles use dotless paths; GitHub Actions requires .github/workflows in the repository."
    }
  ],
  "artifact_file_mappings": [
    {
      "bundle_path": "page-contract-report.json",
      "repo_path": "page_contract_reports/page-contract-report.json",
      "reason": "Page Contract Check artifact ZIP exposes report JSON at root; selector expects page_contract_reports/."
    },
    {
      "bundle_path": "page-contract-report.md",
      "repo_path": "page_contract_reports/page-contract-report.md",
      "reason": "Page Contract Check artifact ZIP exposes report Markdown at root; selector expects page_contract_reports/."
    },
    {
      "bundle_path": "transition-replay-report.json",
      "repo_path": "transition_replay_reports/transition-replay-report.json",
      "reason": "Transition Replay Check artifact ZIP exposes report JSON at root; selector expects transition_replay_reports/."
    },
    {
      "bundle_path": "transition-replay-report.md",
      "repo_path": "transition_replay_reports/transition-replay-report.md",
      "reason": "Transition Replay Check artifact ZIP exposes report Markdown at root; selector expects transition_replay_reports/."
    }
  ],
  "protected_paths": [
    ".git/",
    ".github/workflows/ingest-bundle.yml"
  ],
  "gate_inputs": {
    "capability_thresholds": "data/capability-threshold-gates-v1.json",
    "capability_scopes": "data/transition-capability-scopes-v1.json",
    "stop_gap_policy": "data/stop-gap-policy-v1.json",
    "dependency_map": "data/dependency-map-v1.json"
  },
  "ledger_outputs": {
    "latest_receipt": "data/latest-bundle-ingestion-receipt-v1.json",
    "ledger_jsonl": "data/bundle-ingestion-ledger-v1.jsonl",
    "fingerprint_index": "data/bundle-fingerprint-index-v1.json"
  },
  "safety": {
    "skip_directory_entries": true,
    "skip_absolute_paths": true,
    "skip_parent_traversal": true,
    "do_not_delete_files": true,
    "apply_only_changed_or_missing_files": true,
    "dotless_workflow_paths_are_mapped": true,
    "known_artifact_reports_are_routed": true,
    "workflow_mutation_requires_privileged_queue": true,
    "unknown_dependency_routes_to_sandbox": true,
    "failed_bundle_does_not_block_queue": true,
    "installed_bundle_is_archived": true,
    "stale_incoming_is_quarantined": true,
    "already_seen_incoming_is_quarantined": true,
    "root_readme_in_uploaded_bundle_is_not_applied": true,
    "missing_bundle_fails_closed": true
  }
}