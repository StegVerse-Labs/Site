{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stegverse.org/schemas/stegmusic/composition-request.v1.json",
  "title": "StegMusic Composition Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "composition_request_id",
    "created_at",
    "profile_scope",
    "session_intent",
    "cultural_scope",
    "historical_scope",
    "audience_and_place_scope",
    "novelty_and_familiarity",
    "instrument_and_tool_availability",
    "rights_constraints",
    "evidence_requirements",
    "execution_gate",
    "authority"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "composition_request_id": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "profile_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile_id", "scope_id", "consent_ref"],
      "properties": {
        "profile_id": {"type": "string"},
        "scope_id": {"type": "string"},
        "consent_ref": {"type": "string"},
        "allowed_personalization_signals": {"type": "array", "items": {"type": "string"}}
      }
    },
    "session_intent": {
      "type": "object",
      "required": ["intent_id", "direction", "intensity"],
      "properties": {
        "intent_id": {"type": "string"},
        "direction": {"type": "string"},
        "intensity": {"type": "number", "minimum": 0, "maximum": 1},
        "duration_target_seconds": {"type": "number", "exclusiveMinimum": 0},
        "explicit_user_text": {"type": ["string", "null"]}
      }
    },
    "cultural_scope": {
      "type": "object",
      "required": ["traditions", "historical_fidelity_target", "innovation_distance"],
      "properties": {
        "traditions": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "historical_fidelity_target": {"type": "number", "minimum": 0, "maximum": 1},
        "innovation_distance": {"type": "number", "minimum": 0, "maximum": 1},
        "excluded_claims": {"type": "array", "items": {"type": "string"}}
      }
    },
    "historical_scope": {
      "type": "object",
      "required": ["periods", "recording_technology_posture"],
      "properties": {
        "periods": {"type": "array", "items": {"type": "string"}},
        "recording_technology_posture": {"type": "string"},
        "allowed_rev ival_or_reinterpretation": {"type": "boolean"}
      }
    },
    "audience_and_place_scope": {
      "type": "object",
      "required": ["audience_function", "place_conditioning"],
      "properties": {
        "audience_function": {"type": "array", "items": {"type": "string"}},
        "place_conditioning": {"type": "array", "items": {"type": "string"}},
        "room_or_environment_profile": {"type": ["string", "null"]}
      }
    },
    "novelty_and_familiarity": {
      "type": "object",
      "required": ["familiarity", "novelty", "seed_influence", "profile_influence"],
      "properties": {
        "familiarity": {"type": "number", "minimum": 0, "maximum": 1},
        "novelty": {"type": "number", "minimum": 0, "maximum": 1},
        "seed_influence": {"type": "number", "minimum": 0, "maximum": 1},
        "profile_influence": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "instrument_and_tool_availability": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["assembly_id", "component_class", "availability"],
        "properties": {
          "assembly_id": {"type": "string"},
          "component_class": {"type": "string"},
          "availability": {"enum": ["AVAILABLE", "LIMITED", "UNAVAILABLE"]},
          "condition_ref": {"type": ["string", "null"]}
        }
      }
    },
    "rights_constraints": {
      "type": "object",
      "required": ["protected_expression_copying_prohibited", "artist_voice_imitation_prohibited", "source_audio_use"],
      "properties": {
        "protected_expression_copying_prohibited": {"const": true},
        "artist_voice_imitation_prohibited": {"const": true},
        "source_audio_use": {"enum": ["NONE", "AUTHORIZED_ONLY"]},
        "required_rights_evidence_refs": {"type": "array", "items": {"type": "string"}}
      }
    },
    "evidence_requirements": {
      "type": "object",
      "required": ["frozen_evidence_packet_id", "required_song_references", "required_corpus_references"],
      "properties": {
        "frozen_evidence_packet_id": {"type": "string"},
        "required_song_references": {"type": "array", "items": {"type": "string"}},
        "required_corpus_references": {"type": "array", "items": {"type": "string"}},
        "unresolved_conflicts": {"type": "array", "items": {"type": "string"}}
      }
    },
    "execution_gate": {
      "type": "object",
      "required": ["evidence_frozen", "rights_gate_passed", "composition_may_execute", "blockers"],
      "properties": {
        "evidence_frozen": {"const": true},
        "rights_gate_passed": {"type": "boolean"},
        "composition_may_execute": {"type": "boolean"},
        "blockers": {"type": "array", "items": {"type": "string"}}
      }
    },
    "authority": {"const": "none"}
  }
}
